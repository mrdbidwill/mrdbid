<% content_for :title, "Mushroom Characters Catalog" %>
<% content_for :meta_description, "Browse the complete catalog of observable mushroom characteristics used for identification in MRDBID." %>

<div class="mb-6">
  <h1 class="text-3xl font-bold mb-2">Mushroom Characters Catalog</h1>
  <p class="text-gray-600">
    Reference list of all observable characteristics used for mushroom identification. No login required.
    <% if user_signed_in? %>
      To add or edit characters on a specimen, open the mushroom and use the character entry tools.
    <% else %>
      <%= link_to "Sign in", new_user_session_path, class: "text-blue-600 hover:underline" %> to record characters on your own specimens.
    <% end %>
  </p>
</div>

<!-- Filters -->
<div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-4">
  <%= form_with url: mr_characters_path, method: :get, local: true, class: "flex flex-wrap gap-3 items-end" do |f| %>
    <div>
      <%= f.label :q, "Search", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :q, value: params[:q], placeholder: "Character name...",
          class: "px-3 py-2 border border-gray-300 rounded-md text-sm w-48" %>
    </div>
    <div>
      <%= f.label :part_id, "Part", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :part_id, @parts, { include_blank: "All parts" },
          class: "px-3 py-2 border border-gray-300 rounded-md text-sm" %>
    </div>
    <div>
      <%= f.label :fungus_type_id, "Fungus Type", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.select :fungus_type_id, @fungus_types, { include_blank: "All types" },
          class: "px-3 py-2 border border-gray-300 rounded-md text-sm" %>
    </div>
    <div class="flex gap-2">
      <%= f.submit "Filter", class: "px-4 py-2 bg-blue-600 hover:bg-blue-700 text-white rounded-md text-sm font-medium cursor-pointer" %>
      <%= link_to "Reset", mr_characters_path, class: "px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-700 rounded-md text-sm font-medium" %>
    </div>
  <% end %>
</div>

<div class="flex items-center justify-between mb-3">
  <p class="text-sm text-gray-500"><%= @mr_characters.total_count %> characters</p>
  <%= paginate @mr_characters, theme: 'tailwind_bar' %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <div class="overflow-x-auto">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Part</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Observation Method</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Fungus Type</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Input Type</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @mr_characters.each do |character| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= character.name %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= character.part&.name || "—" %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= character.observation_method&.name || "—" %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= character.fungus_type&.name || "Universal" %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= character.display_option&.name || "—" %></td>
          </tr>
        <% end %>
        <% if @mr_characters.empty? %>
          <tr>
            <td colspan="5" class="px-4 py-8 text-center text-gray-500">No characters found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<div class="mt-4">
  <%= paginate @mr_characters, theme: 'tailwind_bar' %>
</div>
