<%= form_with(model: mr_character, class: "contents") do |form| %>
  <% if mr_character.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(mr_character.errors.count, "error") %> prohibited this mr_character from being saved:</h2>

      <ul class="list-disc ml-6">
        <% mr_character.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :name %>
    <%= form.text_field :name, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": mr_character.errors[:name].none?, "border-red-400 focus:outline-red-600": mr_character.errors[:name].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :display_options_id %>
    <%= form.text_field :display_options_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": mr_character.errors[:display_options_id].none?, "border-red-400 focus:outline-red-600": mr_character.errors[:display_options_id].any?}] %>
  </div>

  <div class="my-5 flex items-center gap-2">
    <%= form.label :lookup %>
    <%= form.checkbox :lookup, class: ["block shadow-sm rounded-md border order-first h-5 w-5", {"border-gray-400 focus:outline-blue-600": mr_character.errors[:lookup].none?, "border-red-400 focus:outline-red-600": mr_character.errors[:lookup].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :parts_id %>
    <%= form.text_field :parts_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": mr_character.errors[:parts_id].none?, "border-red-400 focus:outline-red-600": mr_character.errors[:parts_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :source_id %>
    <%= form.text_field :source_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": mr_character.errors[:source_id].none?, "border-red-400 focus:outline-red-600": mr_character.errors[:source_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :entered_by_id %>
    <%= form.text_field :entered_by_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": mr_character.errors[:entered_by_id].none?, "border-red-400 focus:outline-red-600": mr_character.errors[:entered_by_id].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
