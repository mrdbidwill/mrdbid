<section aria-labelledby="form-title" class="max-w-2xl mx-auto py-6">
  <h2 id="form-title" class="text-xl font-semibold text-gray-800 mb-6 text-center">
    Create or Edit MR Character (from _form.html.erb)
  </h2>

  <%= form_with(model: mr_character, class: "contents") do |form| %>
    <!-- Error Messages -->
    <% if mr_character.errors.any? %>
      <div id="error_explanation" class="bg-red-50 text-red-500 px-4 py-2 rounded-md shadow-sm">
        <h2 class="font-bold mb-2">
          <%= pluralize(mr_character.errors.count, "error") %> prohibited this MR Character from being saved:
        </h2>
        <ul class="list-disc ml-6">
          <% mr_character.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Fields Group -->
    <div class="gap-4">
      <!-- Name Field -->
      <div class="my-5">
        <%= form.label :name, "Name", class: "block font-medium text-gray-700" %>
        <%= form.text_field :name, autofocus: true, class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600 #{mr_character.errors[:name].any? ? 'border-red-400' : 'border-gray-400'}" %>
      </div>

      <!-- Display Option -->
      <div class="my-5">
        <%= form.label :display_option_id, "Display Option", class: "block font-medium text-gray-700" %>
        <%= form.collection_select :display_option_id,
                                   LookupTables::DisplayOption.all,
                                   :id,
                                   :safe_name,
                                   prompt: "Select Display Option",
                                   class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600" %>
      </div>

      <!-- Part -->
      <div class="my-5">
        <%= form.label :part_id, "Part", class: "block font-medium text-gray-700" %>
        <%= form.collection_select :part_id,
                                   LookupTables::Part.all,
                                   :id,
                                   :safe_name,
                                   prompt: "Select Part",
                                   class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600" %>
      </div>

      <!-- Source -->
      <div class="my-5">
        <%= form.label :source_id, "Source", class: "block font-medium text-gray-700" %>
        <%= form.collection_select :source_id,
                                   Source.all,
                                   :id,
                                   :title,
                                   prompt: "Select Source",
                                   class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600" %>
      </div>


    <!-- Submit Button -->
      <div class="mt-5">
        <%= form.submit "Save", class: "rounded-md px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-medium" %>
      </div>
  <% end %>
  </div>
</section>