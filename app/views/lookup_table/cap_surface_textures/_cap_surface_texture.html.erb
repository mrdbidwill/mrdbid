<div id="<%= dom_id cap_surface_texture %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= cap_surface_texture.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= cap_surface_texture.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Comments:</strong>
    <%= cap_surface_texture.comments %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Source:</strong>
    <%= cap_surface_texture.source %>
  </div>
</div>
