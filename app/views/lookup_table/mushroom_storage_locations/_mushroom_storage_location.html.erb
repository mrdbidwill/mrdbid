<div id="<%= dom_id mushroom_storage_location %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= mushroom_storage_location.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= mushroom_storage_location.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Comments:</strong>
    <%= mushroom_storage_location.comments %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Source:</strong>
    <%= mushroom_storage_location.source %>
  </div>
</div>
