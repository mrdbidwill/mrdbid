<div id="<%= dom_id source %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Title:</strong>
    <%= source.title %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Author:</strong>
    <%= source.author %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Ref:</strong>
    <%= source.ref %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Item code:</strong>
    <%= source.item_code %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Comment:</strong>
    <%= source.comment %>
  </div>
  <div>
    <strong class="block font-medium mb-1">My rating:</strong>
    <%= source.my_rating %>
  </div>
  <div>
    <strong class="block font-medium mb-1">My comment:</strong>
    <%= source.my_comment %>
  </div>
</div>
