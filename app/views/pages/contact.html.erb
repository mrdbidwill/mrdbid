<h1>Contact Us</h1>
<p>If you have questions or feedback, use the form below.</p>

<%= form_with url: '/contact', method: :post, local: true do %>
  <div>
    <label for="name">Name</label>
    <%= text_field_tag :name, nil, placeholder: "Enter your name" %>
  </div>
  <div>
    <label for="email">Email</label>
    <%= email_field_tag :email, nil, placeholder: "Enter your email" %>
  </div>
  <div>
    <label for="message">Message</label>
    <%= text_area_tag :message, nil, placeholder: "Enter your message", rows: 4 %>
  </div>
  <div>
    <%= submit_tag "Submit", class: "btn btn-primary" %>
  </div>
<% end %>