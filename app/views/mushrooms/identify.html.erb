<% content_for :title, "Identify #{@mushroom.name}" %>
<% character_step_path = edit_flow_mushroom_path(@mushroom, step: "characters") %>
<% back_path = @return_to.presence %>
<% back_path = mushroom_path(@mushroom) if back_path.blank? || back_path == character_step_path %>
<% selected_value = @selected_character ? "#{@selected_character.part&.name} / #{@selected_character.observation_method&.name}: #{@selected_character.name.to_s.tr("_", " ")}" : "" %>

<div class="w-full auto-margins">
  <div class="mb-4">
    <%= link_to back_path,
                class: "inline-flex items-center gap-2 px-4 py-2 rounded-md bg-indigo-600 hover:bg-indigo-700 text-white font-medium transition" do %>
      <span>Back</span>
    <% end %>
  </div>

  <%= render "mushrooms/taxonomy_quick_link", mushroom: @mushroom %>

  <section class="bg-white border border-gray-200 rounded-lg p-4 mb-5 shadow-sm">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @mushroom.name %></h1>
        <div class="mt-2 flex flex-wrap items-center gap-3 text-sm text-gray-700">
          <span><strong class="text-green-700"><%= @entered_character_rows.size %></strong> completed</span>
          <span class="text-gray-400">|</span>
          <span><strong><%= @characters.size %></strong> searchable characters</span>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border border-indigo-200 rounded-lg p-4 mb-5 shadow-sm"
           data-controller="quick-character-entry"
           data-quick-character-entry-selected-id-value="<%= @selected_character&.id %>">
    <label for="quick-character-search" class="block text-sm font-semibold text-gray-900 mb-2">
      Character
    </label>
    <div class="relative">
      <input id="quick-character-search"
             type="search"
             value="<%= selected_value %>"
             placeholder="Start typing a character name"
             autocomplete="off"
             data-quick-character-entry-target="search"
             data-action="input->quick-character-entry#search focus->quick-character-entry#search keydown->quick-character-entry#navigate"
             class="w-full rounded-md border border-gray-300 px-4 py-3 text-base shadow-sm focus:border-indigo-500 focus:ring-indigo-500">

      <div data-quick-character-entry-target="menu"
           class="hidden absolute z-30 mt-1 w-full max-h-80 overflow-y-auto rounded-md border border-gray-300 bg-white shadow-lg">
        <% @characters.each do |character| %>
          <% label = "#{character.part&.name} / #{character.observation_method&.name}: #{character.name.to_s.tr("_", " ")}" %>
          <% row = @entered_character_rows.find { |entered| entered.mr_character_id == character.id } %>
          <%= link_to identify_mushroom_path(@mushroom, return_to: @return_to, mr_character_id: character.id),
                      class: "block px-4 py-3 border-b border-gray-100 hover:bg-indigo-50 focus:bg-indigo-50 focus:outline-none",
                      data: {
                        quick_character_entry_target: "option",
                        search_text: label.downcase,
                        character_id: character.id
                      } do %>
            <span class="block text-sm font-semibold text-gray-900"><%= character.name.to_s.tr("_", " ") %></span>
            <span class="block text-xs text-gray-600">
              <%= character.part&.name %> / <%= character.observation_method&.name %>
              <% if row %>
                <span class="ml-2 text-green-700 font-medium">Completed</span>
              <% end %>
            </span>
          <% end %>
        <% end %>
        <div data-quick-character-entry-target="empty"
             class="hidden px-4 py-3 text-sm text-gray-600">
          No matching characters.
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white border border-gray-200 rounded-lg p-4 mb-5 shadow-sm">
    <% if @selected_character %>
      <% character = @selected_character %>
      <% char_mushroom = @selected_character_row %>
      <% is_color = (character.display_option&.name&.downcase == "color") || character.display_option_id == 6 %>

      <div class="mb-4">
        <h2 class="text-lg font-semibold text-gray-900"><%= character.name.to_s.tr("_", " ") %></h2>
        <div class="text-sm text-gray-600">
          <%= character.part&.name %> / <%= character.observation_method&.name %>
        </div>
        <% if character.description.present? %>
          <p class="mt-2 text-sm text-gray-700"><%= character.description %></p>
        <% end %>
      </div>

      <% if is_color %>
        <%= render "shared/color_picker_modal",
                   character: character,
                   mushroom_id: @mushroom.id,
                   current_color_id: char_mushroom&.character_value.to_i,
                   redirect_path: @identify_path %>
      <% else %>
        <%= form_with url: mr_character_mushrooms_path, method: :post, data: { turbo: true }, html: { class: "space-y-4" } do |f| %>
          <%= hidden_field_tag :mushroom_id, @mushroom.id %>
          <%= hidden_field_tag :mr_character_id, character.id %>
          <%= hidden_field_tag :redirect_to, @identify_path %>
          <div>
            <%= render partial: "mushrooms/character_input",
                       locals: {
                         f: f,
                         character: character,
                         current_value: char_mushroom&.character_value,
                         compact_radio: false
                       } %>
          </div>
          <%= f.submit(char_mushroom ? "Update Character" : "Save Character",
                       class: "inline-flex px-5 py-2.5 rounded-md bg-green-600 hover:bg-green-700 text-white font-semibold transition") %>
        <% end %>
      <% end %>
    <% else %>
      <div class="py-6 text-center text-gray-600">
        Select a character above to enter its value.
      </div>
    <% end %>
  </section>

  <section class="bg-white border border-green-200 rounded-lg p-4 shadow-sm">
    <div class="flex items-center justify-between gap-3 mb-3">
      <h2 class="text-lg font-semibold text-green-900">Completed Characters</h2>
      <span class="text-sm text-green-700"><%= @entered_character_rows.size %> total</span>
    </div>

    <% if @entered_character_rows.any? %>
      <div class="divide-y divide-gray-100">
        <% @entered_character_rows.each do |row| %>
          <% character = row.mr_character %>
          <% next unless character %>
          <%= link_to identify_mushroom_path(@mushroom, return_to: @return_to, mr_character_id: character.id),
                      class: "block py-3 hover:bg-green-50 px-2 rounded" do %>
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-1">
              <div>
                <div class="font-medium text-gray-900"><%= character.name.to_s.tr("_", " ") %></div>
                <div class="text-xs text-gray-600"><%= character.part&.name %> / <%= character.observation_method&.name %></div>
              </div>
              <div class="text-sm text-gray-800 md:text-right">
                <%= character_value_summary(row) %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <p class="text-sm text-gray-600">No characters have been completed for this specimen yet.</p>
    <% end %>
  </section>
</div>
