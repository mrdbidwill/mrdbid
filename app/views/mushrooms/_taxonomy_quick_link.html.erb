<% target_path = local_assigns[:target_path] %>
<% if target_path.blank? %>
  <% flow_params = { step: "taxonomy" } %>
  <% flow_params[:core_only] = core_only if local_assigns.key?(:core_only) %>
  <% target_path = edit_flow_mushroom_path(mushroom, flow_params) %>
<% end %>

<div class="my-4 border border-purple-300 rounded-lg bg-purple-50 p-3">
  <div class="flex flex-wrap items-center justify-between gap-2">
    <p class="text-sm text-purple-900 font-medium">
      Need to set or update taxonomic candidates?
    </p>
    <%= link_to "Set/Edit Genera + Species",
                target_path,
                class: "inline-flex items-center px-3 py-1.5 rounded bg-purple-600 hover:bg-purple-700 text-white text-sm font-semibold" %>
  </div>
</div>
