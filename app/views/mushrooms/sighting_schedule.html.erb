<% content_for :title, "Fungus Sighting Schedule" %>

<div class="mb-4 flex flex-wrap items-center gap-2">
  <h1 class="text-3xl font-bold text-gray-900">Fungus Sighting Schedule</h1>
  <%= link_to "Back to Mushrooms", mushrooms_path, class: "btn" %>
</div>

<p class="muted mb-4">
  Sorted by collection month, then state, then city.
</p>

<%= render "shared/pagination", collection: @mushrooms %>

<% if @mushrooms&.any? %>
  <div class="overflow-x-auto mt-4 mb-6">
    <table class="min-w-full border border-gray-300 bg-white rounded">
      <thead class="bg-gray-100">
        <tr>
          <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">Month</th>
          <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">State</th>
          <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">City</th>
          <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">Observation Name</th>
          <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">Genus / Species</th>
          <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">Collection Date</th>
        </tr>
      </thead>
      <tbody>
        <% @mushrooms.each do |mushroom| %>
          <% genus_name = mushroom.genera.first&.name&.capitalize %>
          <% species_name = mushroom.species.first&.name %>
          <% scientific_name = [genus_name, species_name].compact.join(" ") %>

          <tr class="odd:bg-white even:bg-gray-50">
            <td class="px-3 py-2 text-sm text-gray-800 border-b border-gray-200"><%= mushroom.collection_date.strftime("%B") %></td>
            <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200"><%= mushroom.state&.name.presence || "Unknown" %></td>
            <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200"><%= mushroom.city.presence || "Unknown" %></td>
            <td class="px-3 py-2 text-sm text-gray-900 border-b border-gray-200">
              <%= link_to mushroom.name.presence || "Unnamed ##{mushroom.id}", mushroom_path(mushroom), class: "text-blue-700 hover:underline font-medium" %>
            </td>
            <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200">
              <% if scientific_name.present? %>
                <em><%= scientific_name %></em>
              <% else %>
                <span class="text-gray-500">Not set</span>
              <% end %>
            </td>
            <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200"><%= mushroom.collection_date.strftime("%m-%d-%Y") %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-gray-600 my-8">No mushrooms with a collection date were found.</p>
<% end %>

<%= render "shared/pagination", collection: @mushrooms %>
