<% content_for :title, "Fungus Sighting Schedule" %>

<div class="mb-4 flex flex-wrap items-center gap-2">
  <h1 class="text-3xl font-bold text-gray-900">Fungus Sighting Schedule</h1>
  <%= link_to "Back to Mushrooms", mushrooms_path, class: "btn" %>
</div>

<p class="muted mb-4">
  Choose a month to view observations. Results are sorted by state, then city.
</p>

<div id="month-list" class="mt-4 mb-6 rounded border border-gray-300 bg-white p-4">
  <p class="text-sm font-semibold text-gray-800 mb-3">Browse by month</p>
  <div class="flex flex-wrap gap-2">
    <% (1..12).each do |month_number| %>
      <% month_name = Date::MONTHNAMES[month_number] %>
      <% month_count = @month_counts[month_number].to_i %>
      <% selected = @selected_month == month_number %>

      <% if month_count.positive? %>
        <%= link_to "#{month_name} (#{month_count})",
                    sighting_schedule_mushrooms_path(month: month_number),
                    class: [
                      "inline-flex items-center rounded border px-3 py-1 text-xs font-medium",
                      (selected ? "border-blue-600 bg-blue-600 text-white" : "border-blue-200 bg-blue-50 text-blue-700 hover:bg-blue-100")
                    ].join(" ") %>
      <% else %>
        <span class="inline-flex items-center rounded border border-gray-200 bg-gray-50 px-3 py-1 text-xs text-gray-400"><%= month_name %></span>
      <% end %>
    <% end %>
  </div>
</div>

<% if @selected_month.present? %>
  <div class="mb-3 flex items-center justify-between">
    <h2 class="text-xl font-semibold text-gray-900">
      <%= Date::MONTHNAMES[@selected_month] %>
    </h2>
    <%= link_to "Clear month filter", sighting_schedule_mushrooms_path, class: "text-xs text-blue-700 hover:underline" %>
  </div>

  <%= render "shared/pagination", collection: @mushrooms %>

  <% if @mushrooms&.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full border border-gray-300 bg-white rounded">
        <thead class="bg-gray-100">
          <tr>
            <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">Image</th>
            <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">State</th>
            <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">City</th>
            <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">Observation Name</th>
            <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">Genus / Species</th>
            <th class="text-left text-xs font-semibold text-gray-700 px-3 py-2 border-b border-gray-300">Collection Date</th>
          </tr>
        </thead>
        <tbody>
          <% @mushrooms.each do |mushroom| %>
            <% genus_name = mushroom.genera.first&.name&.capitalize %>
            <% species_name = mushroom.species.first&.name %>
            <% scientific_name = [genus_name, species_name].compact.join(" ") %>
            <% first_image = mushroom.image_mushrooms.find { |image| image.image_file.attached? } %>

            <tr class="odd:bg-white even:bg-gray-50">
              <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200">
                <% if first_image %>
                  <%= link_to mushroom_path(mushroom) do %>
                    <%= image_tag(
                          url_for(first_image.image_file.variant(
                            resize_to_fill: [72, 72],
                            format: :webp,
                            saver: { strip: true, quality: 70, effort: 4 }
                          )),
                          alt: "#{mushroom.name.presence || "Unnamed ##{mushroom.id}"} thumbnail",
                          class: "h-12 w-12 rounded object-cover border border-gray-200",
                          loading: "lazy"
                        ) %>
                  <% end %>
                <% else %>
                  <div class="h-12 w-12 rounded border border-dashed border-gray-300 bg-gray-100 text-[10px] text-gray-500 flex items-center justify-center">
                    No image
                  </div>
                <% end %>
              </td>
              <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200"><%= mushroom.state&.name.presence || "Unknown" %></td>
              <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200"><%= mushroom.city.presence || "Unknown" %></td>
              <td class="px-3 py-2 text-sm text-gray-900 border-b border-gray-200">
                <%= link_to mushroom.name.presence || "Unnamed ##{mushroom.id}", mushroom_path(mushroom), class: "text-blue-700 hover:underline font-medium" %>
              </td>
              <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200">
                <% if scientific_name.present? %>
                  <em><%= scientific_name %></em>
                <% else %>
                  <span class="text-gray-500">Not set</span>
                <% end %>
              </td>
              <td class="px-3 py-2 text-sm text-gray-700 border-b border-gray-200"><%= mushroom.collection_date.strftime("%m-%d-%Y") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-gray-600 my-8">No mushrooms were found for <%= Date::MONTHNAMES[@selected_month] %>.</p>
  <% end %>

  <%= render "shared/pagination", collection: @mushrooms %>
<% else %>
  <p class="text-gray-600 my-8">Select a month above to show observations.</p>
<% end %>
