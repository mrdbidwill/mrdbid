<% content_for :title, "Field Guide Editor - #{@mushroom.name}" %>

<%
  guide_path         = edit_guide_mushroom_path(@mushroom, core_only: @core_only)
  return_to_param    = params[:return_to].presence
  back_path          = return_to_param || mushroom_path(@mushroom)
  total_entered      = @entered_chars_by_id.size
  total_chars        = @guide_sections.sum { |s| s[:total_count] }
  sections_with_data = @guide_sections.count { |s| s[:entered_count] > 0 }
%>

<div class="w-full space-y-4"
     data-controller="bulk-character-update"
     data-bulk-character-update-mushroom-id-value="<%= @mushroom.id %>"
     data-bulk-character-update-redirect-path-value="<%= guide_path %>">

  <%# Header %>
  <div class="flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @mushroom.name %></h1>
      <p class="text-sm text-gray-500 mt-0.5">Field Guide Character Editor</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <%= link_to "Back", back_path,
                  class: "inline-flex items-center px-3 py-1.5 rounded bg-gray-200 hover:bg-gray-300 text-gray-800 text-sm font-medium" %>
      <%= link_to "View Mushroom", mushroom_path(@mushroom),
                  class: "inline-flex items-center px-3 py-1.5 rounded bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium" %>
      <%= link_to "Flow Editor", edit_flow_mushroom_path(@mushroom, core_only: @core_only, step: "characters"),
                  class: "inline-flex items-center px-3 py-1.5 rounded bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium" %>
      <%= link_to "Matrix Editor", edit_matrix_mushroom_path(@mushroom, core_only: @core_only),
                  class: "inline-flex items-center px-3 py-1.5 rounded bg-purple-600 hover:bg-purple-700 text-white text-sm font-medium" %>
    </div>
  </div>

  <%# Progress and controls %>
  <div class="bg-white border border-gray-300 rounded-lg p-4 space-y-3">
    <% pct = total_chars > 0 ? (total_entered * 100.0 / total_chars).round : 0 %>
    <div class="flex items-center justify-between text-sm mb-1">
      <span class="font-semibold text-gray-700">
        <%= total_entered %> of <%= total_chars %> characters entered
        (<%= sections_with_data %> of <%= @guide_sections.size %> sections have data)
      </span>
      <span class="text-gray-500"><%= pct %>%</span>
    </div>
    <div class="w-full bg-gray-200 rounded-full h-2.5">
      <div class="bg-green-500 h-2.5 rounded-full" style="width: <%= pct %>%"></div>
    </div>

    <div class="flex flex-wrap items-center gap-3 text-sm pt-1">
      <span class="font-semibold text-gray-700">Character set:</span>
      <div class="inline-flex rounded-md border border-gray-300 overflow-hidden">
        <%= link_to "Core",
                    edit_guide_mushroom_path(@mushroom, core_only: true, return_to: return_to_param),
                    class: "px-3 py-1.5 font-medium #{@core_only ? 'bg-blue-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50'}" %>
        <%= link_to "All",
                    edit_guide_mushroom_path(@mushroom, core_only: false, return_to: return_to_param),
                    class: "px-3 py-1.5 font-medium #{!@core_only ? 'bg-blue-600 text-white' : 'bg-white text-gray-700 hover:bg-gray-50'}" %>
      </div>
      <% if @core_fallback %>
        <span class="text-xs text-amber-700 bg-amber-50 border border-amber-200 rounded px-2 py-1">
          No core characters defined - showing all.
        </span>
      <% end %>
    </div>
  </div>

  <%# Sticky save bar %>
  <div class="sticky top-0 z-20 bg-white border border-gray-300 rounded-lg px-4 py-3 flex flex-wrap items-center justify-between gap-3 shadow-sm">
    <p class="text-sm text-gray-600">
      <strong>Individual Save:</strong> Use the "Update" / "Add" button on each character.
      &nbsp;
      <strong>Bulk Save:</strong> Edit multiple fields then click "Save All Changes". Modified fields highlight in yellow.
    </p>
    <button type="button"
            data-bulk-character-update-target="saveButton"
            data-action="click->bulk-character-update#saveAll"
            disabled
            class="whitespace-nowrap px-5 py-2 rounded-lg font-semibold text-white bg-gray-400 cursor-not-allowed transition shadow">
      Save All Changes
    </button>
  </div>

  <%# Field guide sections %>
  <% @guide_sections.each do |section| %>
    <% part          = section[:part] %>
    <% method_groups = section[:method_groups] %>
    <% entered       = section[:entered_count] %>
    <% total         = section[:total_count] %>
    <% has_data      = entered > 0 %>

    <details class="bg-white border rounded-lg overflow-hidden <%= has_data ? 'border-green-300' : 'border-gray-300' %>"
             <%= has_data ? "open" : "" %>>

      <summary class="flex items-center justify-between gap-3 px-4 py-3 cursor-pointer select-none
                      <%= has_data ? 'bg-green-50 hover:bg-green-100' : 'bg-gray-50 hover:bg-gray-100' %>">
        <div class="flex items-center gap-3 min-w-0">
          <% if has_data %>
            <span class="text-green-600 font-bold text-lg leading-none">&#10003;</span>
          <% else %>
            <span class="text-gray-400 font-bold text-lg leading-none">&#9675;</span>
          <% end %>
          <h2 class="text-lg font-bold <%= has_data ? 'text-green-900' : 'text-gray-800' %> truncate">
            <%= part.name %>
          </h2>
          <% if method_groups.size > 1 %>
            <div class="hidden sm:flex flex-wrap gap-1">
              <% method_groups.each do |mg| %>
                <span class="text-xs bg-gray-200 text-gray-600 rounded-full px-2 py-0.5">
                  <%= mg[:method]&.name %>
                </span>
              <% end %>
            </div>
          <% else %>
            <span class="text-xs text-gray-500"><%= method_groups.first&.dig(:method)&.name %></span>
          <% end %>
        </div>
        <div class="flex items-center gap-2 flex-shrink-0">
          <span class="text-sm font-semibold px-2.5 py-1 rounded-full
                       <%= has_data ? 'bg-green-200 text-green-800' : 'bg-gray-200 text-gray-600' %>">
            <%= entered %> / <%= total %>
          </span>
          <svg class="w-5 h-5 text-gray-400 transition-transform details-chevron"
               fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </div>
      </summary>

      <div class="p-4 space-y-5">
        <% method_groups.each do |mg| %>
          <% if method_groups.size > 1 %>
            <h3 class="text-sm font-semibold text-gray-500 uppercase tracking-wide border-b border-gray-200 pb-1">
              <%= mg[:method]&.name %>
            </h3>
          <% end %>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
            <% mg[:characters].each do |character| %>
              <% char_mushroom = @entered_chars_by_id[character.id] %>
              <% is_entered    = char_mushroom.present? %>
              <% is_color      = character.display_option_id == 6 ||
                                 character.display_option&.name&.downcase == "color" %>

              <div class="border-2 rounded-lg p-3 transition hover:shadow-md
                          <%= is_entered ? 'border-green-300 bg-green-50' : 'border-gray-200 bg-white' %>"
                   data-character-card>

                <div class="mb-2">
                  <div class="text-lg font-bold text-gray-900 break-words leading-tight">
                    <%= character.name.to_s.tr("_", " ") %>
                  </div>
                  <% if character.description.present? %>
                    <div class="text-xs text-gray-500 mt-0.5">
                      <%= truncate(character.description, length: 90) %>
                    </div>
                  <% end %>
                </div>

                <% if is_entered && !is_color %>
                  <% key = display_option_key(character) %>
                  <% boolean_keys = %w[boolean_yes_no boolean_true_false boolean_present_absent checkbox] %>
                  <% unless boolean_keys.include?(key) || key == "radio" || key == "9" %>
                    <div class="mb-2 text-sm bg-white px-2 py-1 rounded border border-gray-200">
                      <span class="font-medium text-gray-700">Current: <%= char_mushroom.character_value %></span>
                    </div>
                  <% end %>
                <% end %>

                <% if is_color %>
                  <% if is_entered %>
                    <% colors = char_mushroom.ordered_colors %>
                    <% if colors.any? %>
                      <div class="flex items-center gap-2 flex-wrap mb-2">
                        <% colors.each_with_index do |color, idx| %>
                          <div class="flex items-center gap-1">
                            <% if color.is_simplified? %>
                              <div class="w-6 h-6 rounded border-2 flex-shrink-0 <%= idx == 0 ? 'border-blue-500' : 'border-gray-300' %>"
                                   style="background-color: <%= color.hex %>"></div>
                            <% else %>
                              <%= image_tag "AMS_colors/banner_50x50/banner_#{color.id}.jpg",
                                            alt: color.common_name,
                                            class: "w-6 h-6 rounded border-2 #{idx == 0 ? 'border-blue-500' : 'border-gray-300'}" %>
                            <% end %>
                            <span class="text-xs <%= idx == 0 ? 'font-semibold' : '' %>">
                              <%= color.common_name %>
                            </span>
                          </div>
                        <% end %>
                      </div>
                    <% end %>
                  <% end %>
                  <%= render "shared/color_picker_modal",
                             character: character,
                             mushroom_id: @mushroom.id,
                             current_color_id: char_mushroom&.character_value.to_i,
                             redirect_path: guide_path %>

                <% else %>
                  <%= form_with url: mr_character_mushrooms_path, method: :post,
                                data: { turbo: true, bulk_character_update_target: "form" } do |f| %>
                    <%= hidden_field_tag :mushroom_id, @mushroom.id %>
                    <%= hidden_field_tag :mr_character_id, character.id %>
                    <%= hidden_field_tag :redirect_to, guide_path %>
                    <div class="flex items-start gap-2 flex-wrap">
                      <div class="flex-1 min-w-0">
                        <%= render partial: "mushrooms/character_input",
                                   locals: { f: f, character: character,
                                             current_value: char_mushroom&.character_value } %>
                      </div>
                      <%= f.submit(is_entered ? "Update" : "Add",
                                  class: "flex-shrink-0 rounded px-3 py-1.5 text-sm font-medium text-white transition #{is_entered ? 'bg-green-600 hover:bg-green-700' : 'bg-blue-600 hover:bg-blue-700'}") %>
                    </div>
                  <% end %>
                <% end %>

              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </details>
  <% end %>

  <%# Bottom save bar %>
  <div class="bg-white border border-gray-200 rounded-lg p-4 flex justify-center shadow-sm">
    <button type="button"
            data-bulk-character-update-target="saveButton"
            data-action="click->bulk-character-update#saveAll"
            disabled
            class="px-6 py-3 rounded-lg font-semibold text-white bg-gray-400 cursor-not-allowed transition shadow-md">
      Save All Changes
    </button>
  </div>

</div>

<style>
  details[open] .details-chevron { transform: rotate(180deg); }
</style>
