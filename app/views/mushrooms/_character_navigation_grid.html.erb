<%
  core_only = params[:core_only].to_s != "false"
  core_chars = nil
  core_has_chars = true
  if core_only
    core_scope = if @mushroom.fungus_type_id.present?
                   MrCharacter.for_fungus_type(@mushroom.fungus_type_id)
                 else
                   MrCharacter.all
                 end
                 .where("JSON_EXTRACT(properties, '$.core') = true")
                 .where.not(display_option_id: 1)
    core_chars = MrCharacter.select_core_for_display(core_scope.to_a, fungus_type_id: @mushroom.fungus_type_id)
    core_has_chars = core_chars.any?
  end
%>

<div id="character-grid" class=" bg-blue-50 lg:bg-blue-100 border border-blue-200 rounded-lg p-4 my-6">
  <div class="flex flex-wrap items-center justify-between gap-3 mb-2">
    <h2 class="text-2xl font-bold text-gray-900">
      <%= (core_only && core_has_chars) ? "Core Character Entry" : "Character Entry by Category" %>
    </h2>
    <div class="inline-flex rounded-md border border-blue-300 overflow-hidden text-sm">
      <%= link_to "Core (Default)",
                  (core_has_chars ? mushroom_core_character_entry_path(@mushroom, index: 0, core_only: true) : edit_mushroom_path(@mushroom, core_only: true, show_part: params[:show_part], show_character_id: params[:show_character_id], anchor: "character-grid")),
                  class: "px-3 py-1.5 font-medium #{ core_only ? 'bg-blue-600 text-white' : 'bg-white text-gray-700 hover:bg-blue-50' }" %>
      <%= link_to "All",
                  edit_mushroom_path(@mushroom, core_only: false, show_part: params[:show_part], show_character_id: params[:show_character_id], anchor: "character-grid"),
                  class: "px-3 py-1.5 font-medium #{ !core_only ? 'bg-blue-600 text-white' : 'bg-white text-gray-700 hover:bg-blue-50' }" %>
    </div>
  </div>
  <p class="text-sm text-gray-600 mb-2">
    <% if core_only && core_has_chars %>
      Step through core characters in sequence.
    <% else %>
      Click on a part to add/edit characters for that category. Each link takes you to a focused editing page.
    <% end %>
  </p>

  <% if core_only && core_has_chars %>
    <div class="bg-white border border-purple-200 rounded-lg p-4 shadow-sm">
      <h3 class="text-lg font-semibold text-purple-900 mb-2">Core Character Sequence</h3>
      <p class="text-sm text-gray-600 mb-3">
        Step through each core character in the saved order. Use Back/Next to move through the list.
      </p>
      <%= link_to "Start Core Entry",
                  mushroom_core_character_entry_path(@mushroom, index: 0, core_only: true),
                  class: "inline-flex items-center px-4 py-2 rounded-md bg-purple-600 hover:bg-purple-700 text-white font-semibold" %>
    </div>
  <% else %>
    <%
      # Build the grid data: parts with their associated observation_methods
      # Filter to only show characters for this mushroom's fungus_type or universal characters
      all_chars = if @mushroom.fungus_type_id.present?
                    MrCharacter.cached_for_fungus_type(@mushroom.fungus_type_id)
                  else
                    MrCharacter.cached_all_with_associations
                  end

      filtered_chars = all_chars.reject { |c|
        c.display_option_id == 1 || c.part_id == 1 || c.observation_method_id == 9
      }

      counts = Hash.new { |h, k| h[k] = Hash.new(0) }
      filtered_chars.each do |c|
        counts[c.part_id][c.observation_method_id] += 1
      end

      parts = Part.order(:name).to_a
      observation_methods = ObservationMethod.order(:name).to_a

      @part_observation_methods = parts.map do |part|
        observation_methods_with_counts = observation_methods.map do |om|
          count = counts.dig(part.id, om.id).to_i
          next if count == 0
          { observation_method: om, count: count }
        end.compact
        next if observation_methods_with_counts.empty?
        { part: part, observation_methods: observation_methods_with_counts }
      end.compact
    %>

    <div class="space-y-2">
      <% @part_observation_methods.each do |data| %>
        <% part = data[:part] %>
        <% observation_methods = data[:observation_methods] %>

        <div class="bg-white border border-gray-200 rounded-lg p-2 hover:shadow-md transition">
          <div class="grid grid-cols-1 md:grid-cols-4 gap-2 items-center">
            <!-- Part Name -->
            <div class="md:col-span-1">
              <h3 class="font-semibold text-gray-800 text-base"><%= part.name %></h3>
              <% if part.description.present? %>
                <p class="text-xs text-gray-500"><%= truncate(part.description, length: 60) %></p>
              <% end %>
            </div>

            <!-- Observation Methods Links -->
            <div class="md:col-span-3">
              <div class="flex flex-wrap gap-2">
                <% observation_methods.each do |om_data| %>
                  <% om = om_data[:observation_method] %>
                  <% count = om_data[:count] %>
                  <%= link_to edit_characters_mushroom_path(@mushroom, observation_method_id: om.id, part_id: part.id, core_only: core_only),
                              class: "inline-flex items-center gap-1 px-3 py-1.5 rounded-md bg-gradient-to-r from-blue-500 to-blue-600 hover:from-blue-600 hover:to-blue-700 text-white text-sm font-medium transition shadow-sm hover:shadow" do %>
                    <span><%= om.name %></span>
                    <span class="bg-white/20 rounded-full px-2 py-0.5 text-xs"><%= count %></span>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="mt-4 pt-3 border-t border-indigo-200">
    <% if core_only && core_has_chars %>
      <p class="text-xs text-gray-500">
        <strong>Workflow:</strong> Save a value, then move Back/Next to continue.
      </p>
    <% else %>
      <p class="text-xs text-gray-500">
        <strong>Workflow:</strong> Click a part button, add/edit characters, then return to this grid to continue.
      </p>
    <% end %>
    <% if core_only %>
      <p class="text-xs text-gray-600 mt-2">
        Showing <strong>Core</strong> characters by default. Switch to All to see every character.
      </p>
    <% end %>
    <% if core_only && !core_has_chars %>
      <p class="text-xs text-amber-700 mt-1">
        No core characters defined yet for this mushroom type. Showing all instead.
      </p>
    <% end %>
    <% if @mushroom.fungus_type_id.present? %>
      <p class="text-xs text-gray-600 mt-2">
        Showing only characters for <strong><%= @mushroom.fungus_type.name %></strong> and universal characters
      </p>
    <% end %>
  </div>
</div>
