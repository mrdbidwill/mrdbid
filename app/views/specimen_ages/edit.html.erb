<% content_for :title, "Editing specimen age" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing specimen age</h1>

  <%= render "form", specimen_age: @specimen_age %>

  <%= link_to "Show this specimen age", @specimen_age, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to specimen ages", specimen_ages_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
