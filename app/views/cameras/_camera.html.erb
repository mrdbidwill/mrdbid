<div id="<%= dom_id camera %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= camera.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= camera.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Comments:</strong>
    <%= camera.comments %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Camera makes:</strong>
    <%= camera.camera_makes_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Camera models:</strong>
    <%= camera.camera_models_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Lens:</strong>
    <%= camera.lens_id %>
  </div>
</div>
