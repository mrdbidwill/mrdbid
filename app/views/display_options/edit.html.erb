<% content_for :title, "Editing display option" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing display option</h1>

  <%= render "form", display_option: @display_option %>

  <%= link_to "Show this display option", @display_option, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to display options", display_options_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
