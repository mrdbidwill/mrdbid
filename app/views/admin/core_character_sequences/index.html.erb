<h1 class="bg-gray-100 text-red-800 mx-auto px-2 py-1 text-3xl text-center">Sequence Core Characters</h1>
<p class="text-center text-gray-700 mb-4">
  Set the display order for core characters. Lower numbers appear first. Leave blank to push a character after all sequenced items.
</p>

<div class="max-w-4xl mx-auto">
  <div class="flex items-center gap-3 mb-4">
    <%= link_to "Back to Admin Dashboard", admin_root_path, class: "inline-flex items-center px-3 py-1.5 rounded-md bg-gray-100 hover:bg-gray-200 text-gray-800 text-sm font-medium" %>
    <%= link_to "Mushroom Characters", admin_mr_characters_path, class: "inline-flex items-center px-3 py-1.5 rounded-md bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium" %>
  </div>

  <div class="mb-4">
    <%= form_with url: admin_core_character_sequences_path, method: :get, local: true, class: "inline-flex items-center gap-2" do %>
      <%= label_tag :fungus_type_id, "Fungus Type", class: "text-sm font-semibold text-gray-700" %>
      <%= select_tag :fungus_type_id,
                     options_from_collection_for_select(@fungus_types, :id, :name, @selected_fungus_type_id),
                     class: "border border-gray-300 rounded px-2 py-1 text-sm" %>
      <%= submit_tag "Load", class: "px-3 py-1.5 rounded-md bg-gray-200 hover:bg-gray-300 text-gray-800 text-sm font-medium" %>
    <% end %>
  </div>

  <% if @characters.any? %>
    <%= form_with url: admin_core_character_sequences_path, method: :patch, local: true do %>
      <%= hidden_field_tag :fungus_type_id, @selected_fungus_type_id %>
      <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
        <table class="min-w-full text-sm" data-controller="core-sequence">
          <thead class="bg-gray-50">
            <tr>
              <th class="text-left px-3 py-2 border-b w-10"></th>
              <th class="text-left px-3 py-2 border-b">Sequence</th>
              <th class="text-left px-3 py-2 border-b">Name</th>
              <th class="text-left px-3 py-2 border-b">Part</th>
              <th class="text-left px-3 py-2 border-b">Observation Method</th>
            </tr>
          </thead>
          <tbody>
            <% @characters.each do |character| %>
              <tr class="border-b hover:bg-blue-50" data-core-sequence-target="row" data-character-id="<%= character.id %>">
                <td class="px-3 py-2 cursor-move text-gray-400">=</td>
                <td class="px-3 py-2 w-28">
                  <%= number_field_tag "core_sequences[#{character.id}]",
                                       @sequence_map[character.id],
                                       class: "w-20 border border-gray-300 rounded px-2 py-1",
                                       min: 0 %>
                </td>
                <td class="px-3 py-2 font-medium">
                  <%= character.name.to_s.tr("_", " ") %>
                </td>
                <td class="px-3 py-2 text-gray-700"><%= character.part&.name %></td>
                <td class="px-3 py-2 text-gray-700"><%= character.observation_method&.name %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="mt-4 flex items-center gap-3">
        <%= submit_tag "Save Core Sequence", class: "px-4 py-2 rounded-md bg-green-600 hover:bg-green-700 text-white font-semibold" %>
        <span class="text-xs text-gray-500">Changes save when you click Save.</span>
      </div>
    <% end %>
  <% else %>
    <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-yellow-800">
      No core characters found. Mark characters as core first.
    </div>
  <% end %>
</div>
