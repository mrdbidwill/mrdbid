<% content_for :title, "Colors" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-1 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-2xl">Colors</h1>

    <p class="text-gray-600 text-sm">
      These colors are set using color patches stored in the <code>AMS_colors</code> folder. I understand that <strong>MILLIONS</strong> of colors are out there, but I'm not going to add them all.
    </p>
    <%= link_to "Back to Admin Dashboard", admin_root_path, class: "rounded-md px-2 py-1 bg-gray-600 hover:bg-gray-500 text-white block font-medium" %>
    <% # link_to "New color", new_admin_color_path, class: "rounded-md px-2 py-1 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="colors" class="w-full">
    <div class="my-3 text-sm text-gray-700 bg-blue-50 border border-blue-200 rounded-lg px-3 py-2">
      <strong>Note:</strong> Simplified color swatches are generated to provide more options for color matching.
      AMS colors use the original AMS image patches when available.
    </div>
    <% if @colors.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full text-sm border border-gray-200 rounded-lg overflow-hidden">
          <thead class="bg-gray-50 text-gray-700">
            <tr>
              <th class="px-3 py-2 text-left">Swatch</th>
              <th class="px-3 py-2 text-left">ID</th>
              <th class="px-3 py-2 text-left">Latin Name</th>
              <th class="px-3 py-2 text-left">Common Name</th>
              <th class="px-3 py-2 text-left">Group</th>
              <th class="px-3 py-2 text-left">Closest Websafe</th>
              <th class="px-3 py-2 text-left">Family</th>
              <th class="px-3 py-2 text-left">Display Order</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            <% @colors.each do |color| %>
              <% asset_path = "AMS_colors/banner_50x50/banner_#{color.id}.jpg" %>
              <% full_path = Rails.root.join("app", "assets", "images", asset_path) %>
              <% image_url = full_path.exist? ? image_path(asset_path) : nil %>
              <tr class="bg-white">
                <td class="px-3 py-2">
                  <% if color.is_simplified? %>
                    <div class="w-10 h-10 rounded border border-gray-300 shadow-sm" style="background-color: <%= color.hex %>"></div>
                  <% else %>
                    <div class="w-10 h-10 rounded border border-gray-300 shadow-sm"
                         style="background-color: <%= color.hex %>; <%= image_url ? "background-image: url('#{image_url}'); background-size: cover; background-position: center;" : "" %>"></div>
                  <% end %>
                  <div class="text-[10px] text-gray-500 mt-1">
                    <%= color.is_simplified? ? "Simplified (generated)" : (image_url ? "AMS" : "AMS (missing image)") %>
                  </div>
                </td>
                <td class="px-3 py-2 font-mono text-xs text-gray-700"><%= color.id %></td>
                <td class="px-3 py-2">
                  <div class="font-medium text-gray-900"><%= color.latin_name %></div>
                </td>
                <td class="px-3 py-2 text-gray-700"><%= color.common_name %></td>
                <td class="px-3 py-2 text-gray-700"><%= color.color_group %></td>
                <td class="px-3 py-2 text-gray-700"><%= color.closest_websafe_color %></td>
                <td class="px-3 py-2 text-gray-700"><%= color.color_family %></td>
                <td class="px-3 py-2 text-gray-700"><%= color.display_order %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-center my-10">No colors found.</p>
    <% end %>
  </div>
</div>
