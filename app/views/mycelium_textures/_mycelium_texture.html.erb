<div id="<%= dom_id mycelium_texture %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Name:</strong>
    <%= mycelium_texture.name %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= mycelium_texture.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Comments:</strong>
    <%= mycelium_texture.comments %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Source:</strong>
    <%= mycelium_texture.source_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Entered by:</strong>
    <%= mycelium_texture.entered_by_id %>
  </div>
</div>
