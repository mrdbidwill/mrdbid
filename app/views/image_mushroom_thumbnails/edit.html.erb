<% content_for :title, "Editing image mushroom thumbnail" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing image mushroom thumbnail</h1>

  <%= render "form", image_mushroom_thumbnail: @image_mushroom_thumbnail %>

  <%= link_to "Show this image mushroom thumbnail", @image_mushroom_thumbnail, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to image mushroom thumbnails", image_mushroom_thumbnails_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
