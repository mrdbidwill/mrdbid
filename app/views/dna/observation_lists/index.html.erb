<% content_for :title, "DNA Downloads" %>

<div class="max-w-6xl mx-auto px-4 py-8">
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-gray-900">DNA Downloads</h1>
    <p class="mt-2 text-gray-700">
      DNA-confirmed iNaturalist observation indexes and genera counts.
    </p>
  </div>

  <% if @project_lists.any? %>
    <section class="mb-8">
      <h2 class="text-xl font-semibold text-gray-900 mb-3">Project Downloads</h2>
      <%= render "list_table", observation_lists: @project_lists %>
    </section>
  <% end %>

  <% if @county_lists.any? %>
    <section>
      <h2 class="text-xl font-semibold text-gray-900 mb-3">County Indexes</h2>
      <%= render "list_table", observation_lists: @county_lists %>
    </section>
  <% end %>

  <% if @project_lists.empty? && @county_lists.empty? %>
    <div class="rounded border border-gray-200 bg-white p-6 text-gray-700">
      No public DNA downloads are available yet.
    </div>
  <% end %>
</div>
