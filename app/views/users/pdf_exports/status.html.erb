<% content_for :title, "PDF Export Status" %>

<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
  <div class="mb-6">
    <%= link_to "← Back", :back, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <h1 class="text-2xl font-bold text-gray-900">PDF Export Status</h1>
    </div>

    <div class="px-6 py-6 space-y-4">
      <% if @export_info[:status] == 'processing' %>
        <div class="text-center py-8">
          <svg class="animate-spin h-12 w-12 mx-auto text-blue-600 mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Processing Your PDF</h2>
          <p class="text-gray-600 mb-4">
            We're generating your PDF. This may take several minutes for large collections.
          </p>
          <p class="text-sm text-gray-500">
            Started: <%= @export_info[:created_at].strftime('%B %d, %Y at %I:%M %p') %>
          </p>
        </div>

        <script>
          setTimeout(function() {
            window.location.reload();
          }, 10000);
        </script>
      <% elsif @export_info[:status] == 'ready' %>
        <div class="text-center py-8">
          <svg class="h-12 w-12 mx-auto text-green-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">PDF Ready!</h2>
          <p class="text-gray-600 mb-4">
            Your PDF export is ready for download.
          </p>
          <p class="text-sm text-gray-500 mb-6">
            File Size: <%= number_to_human_size(@export_info[:file_size]) %><br>
            Created: <%= @export_info[:created_at].strftime('%B %d, %Y at %I:%M %p') %><br>
            Expires: <%= (@export_info[:created_at] + 7.days).strftime('%B %d, %Y at %I:%M %p') %>
          </p>

          <%= link_to "Download PDF",
                      users_pdf_export_download_path(id: @export_id),
                      class: "inline-block btn-primary px-6 py-3 text-lg" %>
        </div>
      <% elsif @export_info[:status] == 'failed' %>
        <div class="text-center py-8">
          <svg class="h-12 w-12 mx-auto text-red-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <h2 class="text-xl font-semibold text-gray-900 mb-2">Export Failed</h2>
          <p class="text-gray-600 mb-4">
            Unfortunately, there was an error creating your PDF.
          </p>
          <% if @export_info[:error].present? %>
            <p class="text-sm text-gray-500 mb-6">
              Error: <%= @export_info[:error] %>
            </p>
          <% end %>

          <%= link_to "Try Again", new_users_pdf_export_path, class: "inline-block btn-primary px-6 py-3" %>
          <%= link_to "Contact Support", contact_path, class: "inline-block btn ml-4 px-6 py-3" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
