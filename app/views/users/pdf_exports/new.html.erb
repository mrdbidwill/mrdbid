<% content_for :title, "Export All Mushrooms to PDF" %>

<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
  <div class="mb-6">
    <%= link_to "← Back", :back, class: "text-blue-600 hover:text-blue-900" %>
  </div>

  <div class="bg-white shadow-md rounded-lg overflow-hidden">
    <div class="px-6 py-4 border-b border-gray-200 bg-gray-50">
      <h1 class="text-2xl font-bold text-gray-900">Export All Mushrooms to PDF</h1>
    </div>

    <div class="px-6 py-6 space-y-4">
      <p class="text-gray-700">
        Generate a PDF of all your mushroom entries, including images and identification details.
      </p>

      <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
        <h2 class="text-lg font-semibold text-blue-900 mb-2">What's Included</h2>
        <ul class="list-disc list-inside text-sm text-blue-800 space-y-1">
          <li><strong><%= @mushroom_count %></strong> mushrooms from your collection</li>
          <li>Key details (fungus type, location, dates, notes)</li>
          <li>Up to 4 images per mushroom (optimized for export)</li>
          <li>Character data, trees, and plants when available</li>
        </ul>
      </div>

      <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4">
        <h2 class="text-lg font-semibold text-yellow-900 mb-2">Important Notes</h2>
        <ul class="list-disc list-inside text-sm text-yellow-800 space-y-1">
          <li>PDF generation runs in the background and may take several minutes</li>
          <li>The download link will be available for 7 days</li>
          <li>You'll be taken to a status page while it processes</li>
        </ul>
      </div>

      <div class="mt-6">
        <%= button_to "Start PDF Export", users_pdf_export_path, method: :post,
            class: "w-full btn-primary text-center py-3 px-4 text-lg",
            data: { confirm: "This will generate a PDF of all your mushrooms. This may take several minutes. Continue?" } %>
      </div>
    </div>
  </div>
</div>
