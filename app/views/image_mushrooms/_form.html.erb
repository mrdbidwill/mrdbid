<%= form_with(model: image_mushroom, class: "contents") do |form| %>
  <% if image_mushroom.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(image_mushroom.errors.count, "error") %> prohibited this image_mushroom from being saved:</h2>

      <ul class="list-disc ml-6">
