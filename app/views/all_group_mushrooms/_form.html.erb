<%= form_with(model: all_group_mushroom, class: "contents") do |form| %>
  <% if all_group_mushroom.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(all_group_mushroom.errors.count, "error") %> prohibited this all_group_mushroom from being saved:</h2>

      <ul class="list-disc ml-6">
        <% all_group_mushroom.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :all_group_id %>
    <%= form.text_field :all_group_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": all_group_mushroom.errors[:all_group_id].none?, "border-red-400 focus:outline-red-600": all_group_mushroom.errors[:all_group_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :mushroom_id %>
    <%= form.text_field :mushroom_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": all_group_mushroom.errors[:mushroom_id].none?, "border-red-400 focus:outline-red-600": all_group_mushroom.errors[:mushroom_id].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
