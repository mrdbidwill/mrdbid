<div class="max-w-md mx-auto mt-10">
  <h2 class="text-xl font-semibold text-gray-800 mb-6 text-center">Forgot your password?</h2>
  <h2>Forgot your password?</h2>

<%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

    <div class="my-5">
      <%= f.label :email, class: "block font-medium text-gray-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600 #{resource.errors[:email].any? ? 'border-red-400' : 'border-gray-400'}" %>
    </div>


  <div class="actions">
    <%= f.submit "Send me reset password instructions" %>
  </div>
<% end %>

<%= render "devise/shared/links" %>
</div>

