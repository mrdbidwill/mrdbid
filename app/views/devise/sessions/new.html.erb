<div class="max-w-md mx-auto mt-10">
  <h2 class="text-xl font-semibold text-gray-800 mb-6 text-center">
    Log in to Your Account - views/devise/sessions/new.html.erb
  </h2>

  <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
    <% if resource.errors.any? %>
      <div class="bg-red-50 text-red-500 px-4 py-2 rounded-md mb-4">
        <%= resource.errors.full_messages.uniq.join(', ') %>
      </div>
    <% end %>
    
    <!-- Email Field -->
    <div class="my-5">
      <%= f.label :email, class: "block font-medium text-gray-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600 #{resource.errors[:email].any? ? 'border-red-400' : 'border-gray-400'}" %>
    </div>

    <!-- Password Field -->
    <div class="my-5">
      <%= f.label :password, class: "block font-medium text-gray-700" %>
      <%= f.password_field :password, autocomplete: "current-password", class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600 #{resource.errors[:password].any? ? 'border-red-400' : 'border-gray-400'}" %>
    </div>

    <!-- Remember Me -->
    <% if devise_mapping.rememberable? %>
      <div class="my-5 flex items-center">
        <%= f.check_box :remember_me, class: "h-4 w-4 text-blue-600 border-gray-300 focus:ring-blue-500" %>
        <label class="ml-2 text-sm text-gray-700">Remember me</label>
      </div>
    <% end %>

    <!-- Submit Button -->
    <div>
      <%= f.submit "Log in", class: "w-full rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium shadow-md" %>
    </div>
  <% end %>
</div>