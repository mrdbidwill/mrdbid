<div class="max-w-md mx-auto mt-10">
  <h2 class="text-xl font-semibold text-gray-800 mb-6 text-center">Sign Up</h2>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    
    <div class="my-5">
      <%= f.label :email, class: "block font-medium text-gray-700" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600 #{resource.errors[:email].any? ? 'border-red-400' : 'border-gray-400'}" %>
    </div>

    <div class="my-5">
      <%= f.label :password, class: "block font-medium text-gray-700" %>
      <%= f.password_field :password, autocomplete: "new-password", class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600 #{resource.errors[:password].any? ? 'border-red-400' : 'border-gray-400'}" %>
    </div>

    <div class="my-5">
      <%= f.label :password_confirmation, class: "block font-medium text-gray-700" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "block shadow-sm rounded-md border px-3 py-2 w-full focus:outline-blue-600 #{resource.errors[:password_confirmation].any? ? 'border-red-400' : 'border-gray-400'}" %>
    </div>

    <div>
      <%= f.submit "Sign up", class: "w-full rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white font-medium shadow-md" %>
    </div>
  <% end %>
</div>