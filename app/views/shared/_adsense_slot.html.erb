<% return unless render_adsense_slot? %>

<div class="my-4 not-prose" aria-label="Advertisement">
  <ins class="adsbygoogle"
       style="display:block"
       data-ad-client="<%= adsense_client_id %>"
       data-ad-slot="<%= adsense_slot_id %>"
       data-ad-format="auto"
       data-full-width-responsive="true"></ins>
</div>
