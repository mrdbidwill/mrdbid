<% content_for :title, "Editing cap margin shape" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing cap margin shape</h1>

  <%= render "form", cap_margin_shape: @cap_margin_shape %>

  <%= link_to "Show this cap margin shape", @cap_margin_shape, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to cap margin shapes", cap_margin_shapes_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
